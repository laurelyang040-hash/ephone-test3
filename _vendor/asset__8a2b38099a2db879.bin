al-800 hover:text-white font-medium "> Pricing  </a><a href="https://checkout.corsproxy.io/affiliates" target="_blank" class="py-3 px-3 rounded-lg text-neutral-300 hover:bg-neutral-800 hover:text-white font-medium inline-flex items-center gap-1.5"> Affiliates <span class="px-1.5 py-0.5 text-[10px] font-semibold bg-gradient-to-r from-blue-500 to-violet-500 text-white rounded-full uppercase"> $ </span> </a><a href="/docs/" target="_blank" class="py-3 px-3 rounded-lg text-neutral-300 hover:bg-neutral-800 hover:text-white font-medium "> Documentation  </a> </div> </nav> <!-- Drawer Footer --> <div class="p-4 border-t border-neutral-700"> <a class="w-full py-2.5 px-3 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-white text-gray-900 hover:opacity-90" href="https://console.corsproxy.io/" onclick="posthog.capture('dashboard_button_click')"> Dashboard </a> </div> </div> </div> <script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('sticky-container');

    const onScroll = () => {
      if (window.scrollY > 0) {
        header?.classList.add('bg-black/60', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
        header?.classList.remove('bg-transparent', 'bg-white', 'shadow-md');
      } else {
        header?.classList.add('bg-transparent');
        header?.classList.remove('bg-black/60', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/20', 'bg-white', 'shadow-md');
      }
    };

    onScroll();
    window.addEventListener('scroll', onScroll);

    // Mobile drawer
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('drawer-overlay');
    const openBtn = document.querySelector('[data-hs-collapse]');
    const closeBtn = document.getElementById('drawer-close');

    const openDrawer = () => {
      drawer?.classList.remove('translate-x-full');
      overlay?.classList.remove('opacity-0', 'pointer-events-none');
      overlay?.classList.add('opacity-100');
      document.body.style.overflow = 'hidden';
    };

    const closeDrawer = () => {
      drawer?.classList.add('translate-x-full');
      overlay?.classList.add('opacity-0', 'pointer-events-none');
      overlay?.classList.remove('opacity-100');
      document.body.style.overflow = '';
    };

    openBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    // Mobile solutions accordion
    const accordionToggle = document.querySelector('[data-accordion-toggle]');
    const accordionContent = document.querySelector('.accordion-content');
    const accordionChevron = document.querySelector('.accordion-chevron');

    accordionToggle?.addEventListener('click', () => {
      accordionContent?.classList.toggle('hidden');
      accordionChevron?.classList.toggle('rotate-180');
    });
  });
</script> <main class="min-h-screen bg-black text-white" data-astro-cid-j7pv25f6> <!-- Hero Section with Globe --> <section class="relative pt-36 sm:pt-40 lg:mt-0" data-astro-cid-j7pv25f6> <div class="border-white/10 border-y" data-astro-cid-j7pv25f6> <div class="mx-auto max-w-7xl px-2" data-astro-cid-j7pv25f6> <div class="bg-black mx-px grid lg:grid-cols-2" data-astro-cid-j7pv25f6> <!-- Left Column: Text Content --> <div class="relative z-10 py-12 lg:py-20 px-8 lg:px-12 flex flex-col justify-center" data-astro-cid-j7pv25f6> <!-- Badge --> <a href="https://github.com/search?q=corsproxy.io&type=code" target="_blank" rel="noopener" class="inline-flex w-fit items-center gap-2 ps-1 pe-2 py-1 rounded-full bg-white/10 border border-white/20 text-sm text-gray-300 mb-8 cursor-pointer hover:scale-105 hover:bg-white/15 transition-all duration-200" data-astro-cid-j7pv25f6> <svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" viewBox="0 0 512 512" class="size-5" data-astro-cid-j7pv25f6><path d="M256 6.3C114.6 6.3 0 120.9 0 262.3c0 113.3 73.3 209 175 242.9 12.8 2.2 17.6-5.4 17.6-12.2 0-6.1-.3-26.2-.3-47.7-64.3 11.8-81-15.7-86.1-30.1-2.9-7.4-15.4-30.1-26.2-36.2-9-4.8-21.8-16.6-.3-17 20.2-.3 34.6 18.6 39.4 26.2 23 38.7 59.8 27.8 74.6 21.1 2.2-16.6 9-27.8 16.3-34.2-57-6.4-116.5-28.5-116.5-126.4 0-27.8 9.9-50.9 26.2-68.8-2.6-6.4-11.5-32.6 2.6-67.8 0 0 21.4-6.7 70.4 26.2 20.5-5.8 42.2-8.6 64-8.6s43.5 2.9 64 8.6c49-33.3 70.4-26.2 70.4-26.2 14.1 35.2 5.1 61.4 2.6 67.8 16.3 17.9 26.2 40.6 26.2 68.8 0 98.2-59.8 120-116.8 126.4 9.3 8 17.3 23.4 17.3 47.4 0 34.2-.3 61.8-.3 70.4 0 6.7 4.8 14.7 17.6 12.2C438.7 471.3 512 375.3 512 262.3c0-141.4-114.6-256-256-256" style="fill-rule:evenodd;clip-rule:evenodd;fill:#fff" data-astro-cid-j7pv25f6></path></svg>
