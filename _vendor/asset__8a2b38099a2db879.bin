  #sticky-container {
    position: fixed;
    inset: 0 auto auto 0;
    z-index: 50;
    width: 100%;
    isolation: isolate;
  }

  #sticky-container::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    z-index: -1;
  }

  .solutions-veil {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .solutions-veil::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: var(--solutions-bg, rgba(15, 15, 15, 0.7));
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    z-index: -1;
