-1ab6e6aceac1.png","uploadDate":"2024-07-01T10:00:00+08:00","duration":"PT5S","contentUrl":"https://filecdn.minimax.chat/public/023fd855-f068-436a-9f68-372bf643cd91.mp4","embedUrl":"https://www.minimaxi.com","publisher":{"@id":"https://www.minimaxi.com/#organization"}},{"@type":"ItemList","@id":"https://www.minimaxi.com/#products","name":"MiniMax Products","itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"MiniMax Agent","description":"Minimize Effort, Maximize Intelligence","image":"https://filecdn.minimax.chat/public/c73b4e40-3465-4710-91f0-8b78936f26cb.png","url":"https://agent.minimaxi.com/","brand":{"@id":"https://www.minimaxi.com/#brand"},"offers":{"@type":"Offer","price":"0","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"https://agent.minimaxi.com/","priceValidUntil":"2026-12-31"},"aggregateRating":{"@type":"AggregateRating","ratingValue":4.8,"bestRating":5,"ratingCount":25000}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"MiniMax Audio","description":"Intrinsic Zero-shot: Pioneering a New Era of AI Speech Generation","image":"https://filecdn.minimax.chat/public/260b07e3-670e-4978-b8fd-653dda5069eb.png","url":"https://www.minimaxi.com/audio","brand":{"@id":"https://www.minimaxi.com/#brand"},"offers":{"@type":"Offer","price":"0","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"https://www.minimaxi.com/audio","priceValidUntil":"2026-12-31"},"aggregateRating":{"@type":"AggregateRating","ratingValue":4.9,"bestRating":5,"ratingCount":50000}}},{"@type":"ListItem","position":3,"item":{"@type":"Product","name":"Hailuo AI Video","description":"Your Stories, Amplified by AI","image":"https://filecdn.minimax.chat/public/b020d5be-0cd4-4293-b727-3e7b96bfb210.png","url":"https://hailuoai.video","brand":{"@id":"https://www.minimaxi.com/#brand"},"offers":{"@type":"Offer","price":"0","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"https://hailuoai.video","priceValidUntil":"2026-12-31"},"aggregateRating":{"@type":"AggregateRating","ratingValue":4.9,"bestRating":5,"ratingCount":80000000}}}]},{"@type":"FAQPage","@id":"https://www.minimaxi.com/#faqpage","name":"MiniMax 常见问题","description":"关于 MiniMax 的常见问题解答","mainEntity":[{"@type":"Question","name":"如何充值账户？支持哪些支付方式？","acceptedAnswer":{"@type":"Answer","text":"MiniMax 开放平台目前支持两种充值方式：在线支付和线下银行转账。进入账户 → 余额，点击充值按钮进行操作。"}},{"@type":"Question","name":"个人账户可以申请公司抬头的发票吗？","acceptedAnswer":{"@type":"Answer","text":"发票抬头必须与实名认证时使用的名称一致。个人账户无法申请公司抬头的发票。如需申请，请升级为企业认证。"}},{"@type":"Question","name":"如何获取 API Key 并探索 API？","acceptedAnswer":{"@type":"Answer","text":"进入账户管理 → API Keys 创建和管理您的 API Keys。查看可用的 API 和使用说明，请访问文档中心 → API 文档。"}},{"@type":"Question","name":"可以为充值金额开具发票吗？","acceptedAnswer":{"@type":"Answer","text":"充值金额不能直接开具发票。只有在消费产生订单或账单后，才能申请开具发票。"}},{"@type":"Question","name":"如何申请更高的资源保障？","acceptedAnswer":{"@type":"Answer","text":"MiniMax 开放平台为付费用户提供充足的资源保障。如需更高级别的保障，请通过 api@minimaxi.com 联系我们。"}},{"@type":"Question","name":"如何使用声音克隆服务？","acceptedAnswer":{"@type":"Answer","text":"声音克隆服务仅在完成个人或企业实名认证后可用。认证完成后，您可以通过 API 调试台 → 声音克隆访问该功能。"}},{"@type":"Question","name":"如何访问所有可用于语音合成的官方音色 ID？","acceptedAnswer":{"@type":"Answer","text":"您可以调用音色 ID 查询 API 获取我们提供的所有官方音色 ID 列表。"}},{"@type":"Question","name":"遇到问题应该怎么办？","acceptedAnswer":{"@type":"Answer","text":"如果您遇到任何问题，请通过邮箱 api@minimaxi.com 联系我们。"}}]}]}</script><main><section class="relative h-[630px] flex flex-col justify-center overflow-hidden  " data-apollo-key="home_banner_list"><div class="w-full max-w-[1320px] mx-auto lg:px-0 mt-[16px]"><div class="relative w-full"><button class="
